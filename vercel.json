{
  "functions": {
    "api/info.py": {
      "runtime": "@vercel/python",
      "maxDuration": 60
    },
    "api/dl.py": {
      "runtime": "@vercel/python",
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" }
      ]
    }
  ]
}
